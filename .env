# Port mapping for TeamCity Web UI
TEAMCITY_HTTP_PORT=8111

# Port mapping for n8n Web UI and webhook endpoint
N8N_HTTP_PORT=5678

# Base URL used by n8n links and webhooks
N8N_BASE_URL=http://localhost:5678

# Port mapping for Ollama HTTP API
OLLAMA_HTTP_PORT=11434

# Base URL for local Ollama API calls from host
OLLAMA_BASE_URL=http://localhost:11434

# Stable small test model for local workflow tests
OLLAMA_MODEL=qwen2.5:1.5b

# Optional n8n runtime settings
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_TIMEZONE=Europe/Berlin
N8N_WEBHOOK_URL=http://localhost:5678/
# Allow workflow nodes to read $env in local lab setup
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
# Allow file nodes to write to explicit paths in this lab
N8N_RESTRICT_FILE_ACCESS_TO=/data/n8n-exports
# Structure snapshot path used by n8n workflow 01_TC_Structure_Sync
TEAMCITY_AI_STRUCTURE_PATH=/data/n8n-exports/teamcity/structure.json
# TeamCity base URL used by n8n inside Docker network
TEAMCITY_BASE_URL_N8N=http://teamcity-server:8111

# Base URL used by all PowerShell scripts when -BaseUrl is omitted
TEAMCITY_BASE_URL=http://localhost:8111

# Optional output folder for advanced MCP reports
# Relative paths are resolved from the repository root
TEAMCITY_REPORT_DIR=reports

# TeamCity personal access token for the CLI scripts in ./teamcity-scripts
# Create the token in the TeamCity UI and paste it here
TEAMCITY_TOKEN=eyJ0eXAiOiAiVENWMiJ9.Q0hZNGJlUF9OWE55UzRUckVhQW1QUjYwYTVy.OTNkYjNkNDctOTZhNy00ZTYwLTg2MzQtZTlkNGRkODUwNTdi