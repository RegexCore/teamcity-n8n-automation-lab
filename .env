# Port mapping for TeamCity Web UI
TEAMCITY_HTTP_PORT=8111

# Base URL used by all PowerShell scripts when -BaseUrl is omitted
TEAMCITY_BASE_URL=http://localhost:8111

# Default values used by create-teamcity-project.ps1 when omitted
TEAMCITY_DEFAULT_PROJECT_ID=demo_project
TEAMCITY_DEFAULT_PROJECT_NAME=Demo Project

# Optional output folder for advanced MCP reports
# Leave empty to store reports in project root
TEAMCITY_REPORT_DIR=

# TeamCity Personal Access Token fuer die CLI-Skripte in ./scripts
# Token im TeamCity UI erstellen und hier eintragen
TEAMCITY_TOKEN=
