    {
      "parameters": {
        "jsCode": "const src = $input.first()?.json ?? {};\nconst body = src.body && typeof src.body === 'object' ? src.body : src;\nconst headers = src.headers && typeof src.headers === 'object' ? src.headers : {};\nconst expectedToken = (($env.N8N_WEBHOOK_TOKEN ?? '') + '').trim();\n\nif (!expectedToken) {\n  throw new Error('Server webhook token is not configured. Set N8N_WEBHOOK_TOKEN in the container environment.');\n}\n\nconst providedToken = (headers['x-webhook-token'] ?? headers['X-Webhook-Token'] ?? headers['authorization'] ?? '').toString().trim();\nif (!providedToken) {\n  throw new Error('Missing webhook token header. Provide X-Webhook-Token.');\n}\n\nconst bearerPrefix = 'Bearer ';\nconst normalizedProvidedToken = providedToken.startsWith(bearerPrefix) ? providedToken.slice(bearerPrefix.length).trim() : providedToken;\nif (normalizedProvidedToken !== expectedToken) {\n  throw new Error('Invalid webhook token.');\n}\n\nconst chatInput = (body.message ?? body.input ?? body.chatInput ?? body.text ?? '').toString().trim();\n\nif (!chatInput) {\n  throw new Error('Webhook payload requires one of: message, input, chatInput, text');\n}\n\nconst providedSessionId = (body.conversationId ?? body.sessionId ?? body.userId ?? '').toString().trim();\nconst sessionId = providedSessionId || `webhook-${Date.now()}`;\n\nreturn [{\n  json: {\n    chatInput,\n    sessionId,\n    webhookPayload: body\n  }\n}];"
      },
