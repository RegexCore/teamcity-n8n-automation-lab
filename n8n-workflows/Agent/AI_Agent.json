  "nodes": [
    {
      "parameters": {
        "jsCode": "const src = $input.first()?.json ?? {};\nlet output = src.output ?? src.text ?? src.response ?? src.answer ?? '';\n\nif (typeof output !== 'string') {\n  try {\n    output = JSON.stringify(output, null, 2);\n  } catch (_) {\n    output = String(output);\n  }\n}\n\nlet fromWebhook = false;\ntry {\n  const normalizedItems = $('Normalize Webhook Input').all();\n  fromWebhook = Array.isArray(normalizedItems) && normalizedItems.length > 0;\n} catch (_) {\n  fromWebhook = false;\n}\n\nreturn [{\n  json: {\n    output: output,\n    text: output,\n    fromWebhook: fromWebhook\n  }\n}];"
      },
