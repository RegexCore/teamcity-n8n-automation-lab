                                         "jsCode":  "var question = (($json.chatInput || \u0027\u0027) + \u0027\u0027).trim();\n\nvar teamcityBaseUrl = \u0027http://teamcity-server:8111\u0027;\nvar teamcityToken = \u0027__TEAMCITY_TOKEN__\u0027;\n\nvar llmSystemPrompt = \u0027You are a CI/CD troubleshooting assistant. Answer in English. Use TeamCity build configuration context when available.\u0027;\n\nreturn [\n  {\n    json: {\n      mode: \u0027chat-teamcity-buildtypes\u0027,\n      input_question: question,\n      teamcity: {\n        baseUrl: teamcityBaseUrl,\n        token: teamcityToken\n      },\n      llm: {\n        endpoint: \u0027http://ollama:11434/api/generate\u0027,\n        model: \u0027qwen2.5:1.5b\u0027,\n        stream: false,\n        options: {\n          temperature: 0.1,\n          top_p: 0.9,\n          num_predict: 300\n        },\n        system_prompt: llmSystemPrompt\n      }\n    }\n  }\n];"
