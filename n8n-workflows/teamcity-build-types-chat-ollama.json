                  {
                      "parameters":  {
                                         "jsCode":  "var reqItem = $items(\u0027Build Chat Request\u0027)[0] || {};\nvar req = reqItem.json || {};\n\nvar src = $json || {};\nvar apiErr = src.error || null;\n\nvar raw = src.body;\nvar parsed = null;\n\nif (raw \u0026\u0026 typeof raw === \u0027object\u0027) {\n  parsed = raw;\n} else if (typeof raw === \u0027string\u0027) {\n  try {\n    parsed = JSON.parse(raw);\n  } catch (e) {\n    parsed = null;\n  }\n} else {\n  parsed = src;\n}\n\nif (!parsed || typeof parsed !== \u0027object\u0027) {\n  parsed = {};\n}\n\nvar tcError = apiErr || parsed.error || null;\n\nvar allBuildTypes = Array.isArray(parsed.buildType) ? parsed.buildType : [];\nvar buildTypesForPrompt = allBuildTypes.slice(0, 20).map(function (b, idx) {\n  return {\n    index: idx + 1,\n    buildTypeId: b.id || null,\n    buildTypeName: b.name || null,\n    projectName: b.projectName || null,\n    paused: typeof b.paused !== \u0027undefined\u0027 ? b.paused : null,\n    webUrl: b.webUrl || null\n  };\n});\n\nvar contextBlock = \u0027\u0027;\nif (tcError) {\n  contextBlock = \u0027TeamCity API error: \u0027 + JSON.stringify(tcError);\n} else if (!buildTypesForPrompt.length) {\n  contextBlock = \u0027No build configurations found in TeamCity.\u0027;\n} else {\n  contextBlock = JSON.stringify(buildTypesForPrompt, null, 2);\n}\n\nvar baseUrl = req.teamcity \u0026\u0026 req.teamcity.baseUrl ? req.teamcity.baseUrl : \u0027\u0027;\n\nvar prompt = [\n  \u0027User question:\u0027,\n  req.input_question || \u0027\u0027,\n  \u0027\u0027,\n  \u0027TeamCity API base URL: \u0027 + baseUrl,\n  \u0027Build configurations context (latest up to 20):\u0027,\n  contextBlock,\n  \u0027\u0027,\n  \u0027Task:\u0027,\n  \u0027- Answer the user question using the TeamCity context.\u0027,\n  \u0027- If there are no build configurations or API errors, explain what to check next.\u0027\n].join(\u0027\\n\u0027);\n\nreturn [\n  {\n    json: {\n      mode: req.mode || \u0027chat-teamcity-buildtypes\u0027,\n      input_question: req.input_question || \u0027\u0027,\n      teamcity_context: {\n        baseUrl: baseUrl || null,\n        build_types_count: allBuildTypes.length,\n        build_types_sample: buildTypesForPrompt,\n        api_error: tcError\n      },\n      llm_request: {\n        endpoint: req.llm \u0026\u0026 req.llm.endpoint ? req.llm.endpoint : \u0027http://ollama:11434/api/generate\u0027,\n        model: req.llm \u0026\u0026 req.llm.model ? req.llm.model : \u0027qwen2.5:1.5b\u0027,\n        system_prompt: req.llm \u0026\u0026 req.llm.system_prompt ? req.llm.system_prompt : \u0027\u0027,\n        prompt: prompt,\n        stream: req.llm \u0026\u0026 typeof req.llm.stream !== \u0027undefined\u0027 ? req.llm.stream : false,\n        options: req.llm \u0026\u0026 req.llm.options ? req.llm.options : {\n          temperature: 0.1,\n          top_p: 0.9,\n          num_predict: 300\n        }\n      }\n    }\n  }\n];"
